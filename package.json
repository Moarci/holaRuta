{
  "name": "holaruta",
  "version": "1.110.0",
  "private": true,
  "description": "HolaRuta – Dein Reise-Spanisch für echte Situationen. Vanilla-JS-Lernkarten-PWA (keine Runtime-Dependencies).",
  "scripts": {
    "test": "node --test test/*.test.js",
    "build": "node build.js",
    "dist": "node build.js --dist",
    "e2e": "node scripts/e2e-modo-profe.mjs",
    "e2e:study": "node scripts/e2e-study.mjs",
    "e2e:verify": "node scripts/e2e-verify.mjs",
    "e2e:cards": "node scripts/e2e-cardcache.mjs",
    "mutation:catalog": "node scripts/mutation/run.mjs --catalog",
    "mutation:engine": "node scripts/mutation/run.mjs --engine",
    "mutation:diff": "node scripts/mutation/run.mjs --catalog --engine --diff",
    "mutation:score": "node scripts/mutation/run.mjs --engine"
  },
  "devDependencies": {
    "esbuild": "0.28.1"
  }
}
