{
  "name": "holaruta",
  "version": "1.125.0",
  "private": true,
  "description": "HolaRuta – Dein Reise-Spanisch für echte Situationen. Vanilla-JS-Lernkarten-PWA (keine Runtime-Dependencies).",
  "scripts": {
    "test": "node --test test/*.test.js",
    "build": "node build.js",
    "dist": "node build.js --dist",
    "dist:launch": "node build.js --dist --edition=launch",
    "e2e": "node scripts/e2e/run.mjs --tier=P0",
    "e2e:smoke": "node scripts/e2e/run.mjs --tier=P0",
    "e2e:full": "node scripts/e2e/run.mjs --tier=P0,P1,P2",
    "e2e:all": "node scripts/e2e/run.mjs --tier=P0,P1,P2,P3",
    "e2e:study": "node scripts/e2e/run.mjs --alias=study",
    "e2e:verify": "node scripts/e2e/run.mjs --alias=verify",
    "e2e:cards": "node scripts/e2e/run.mjs --alias=cards",
    "e2e:profe": "node scripts/e2e/run.mjs --alias=modo-profe",
    "e2e:composer": "node scripts/e2e-composer.mjs",
    "audit:levels": "node tools/audit-levels.js",
    "audit:locals": "node tools/audit-locals.js",
    "geo:generate": "node scripts/geo/generate.mjs",
    "geo:prerender": "node scripts/geo/prerender.mjs",
    "geo:verify": "node scripts/geo/verify.mjs",
    "mutation:catalog": "node scripts/mutation/run.mjs --catalog",
    "mutation:engine": "node scripts/mutation/run.mjs --engine",
    "mutation:diff": "node scripts/mutation/run.mjs --catalog --engine --diff",
    "mutation:score": "node scripts/mutation/run.mjs --engine"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4"
  },
  "devDependencies": {
    "esbuild": "0.28.1"
  }
}
