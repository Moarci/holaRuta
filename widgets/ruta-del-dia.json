{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "${title}",
      "weight": "Bolder",
      "size": "Medium",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "${subtitle}",
      "isSubtle": true,
      "wrap": true,
      "spacing": "None"
    }
  ],
  "actions": [
    {
      "type": "Action.Execute",
      "title": "Üben",
      "verb": "open-ruta"
    }
  ]
}
