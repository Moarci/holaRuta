{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node build.js --dist --edition=launch",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/v1/:path*", "destination": "/api/v1/:path*" }
  ],
  "crons": [
    { "path": "/api/cron/purge-events", "schedule": "0 3 * * *" }
  ],
  "functions": {
    "api/**/*.js": { "memory": 256, "maxDuration": 15 }
  }
}
