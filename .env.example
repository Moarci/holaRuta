# HolaRuta Backend – Serverseitige Secrets (Vercel Env-Vars). NIE im Client.
# Der einzige öffentliche Wert ist config.sync.apiBase (= App-Origin, siehe editions/launch.js).

# Supabase-Projekt (EU-Region, z. B. Frankfurt)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key            # nur für den Auth-Flow (signInWithOtp/verifyOtp)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # DB-Zugriff der Functions (bypasst RLS)

# Passwortloser E-Mail-Versand: in Supabase Auth als SMTP/Resend hinterlegen
# (keine App-seitige Variable nötig – Supabase verschickt die OTP-/Magic-Link-Mails).

# Telemetrie-Retention (Cron). Default 90 Tage.
EVENT_RETENTION_DAYS=90
# Schützt den Cron-Endpunkt; Vercel Cron sendet ihn als Bearer-Header.
CRON_SECRET=generate-a-long-random-string
